@ECHO OFF
REM DELTREE MVP manual check

MKDIR DTREE
MKDIR DTREE\L1
MKDIR DTREE\L1\L2
ECHO hello> DTREE\ROOT.TXT
ECHO world> DTREE\L1\L2\FILE.TXT
ECHO noext> DTREE\L1\L2\NOEXT
ATTRIB +R DTREE\L1\L2\FILE.TXT

ECHO Running DELTREE /Y...
DELTREE /Y DTREE

IF EXIST DTREE\ROOT.TXT ECHO FAIL: ROOT.TXT still exists
IF EXIST DTREE\L1\L2\FILE.TXT ECHO FAIL: FILE.TXT still exists
IF EXIST DTREE ECHO FAIL: DTREE directory still exists
