@ECHO OFF
REM XCOPY verification: copy from B: to C: and compare payload with DIFF.

DELTREE /Y C:\XCOPYCHK

ECHO Running XCOPY...
XCOPY B:\XCOPY\EXAMPLES\01_VERFY\SRC C:\XCOPYCHK /Y /E /H /K /V

ECHO Verifying copied files...
DIFF -s B:\XCOPY\EXAMPLES\01_VERFY\SRC\ROOT.TXT C:\XCOPYCHK\ROOT.TXT
DIFF -s B:\XCOPY\EXAMPLES\01_VERFY\SRC\ROOT\SUB\FILE1.TXT C:\XCOPYCHK\ROOT\SUB\FILE1.TXT
DIFF -s B:\XCOPY\EXAMPLES\01_VERFY\SRC\ROOT\SUB\FILE2.TXT C:\XCOPYCHK\ROOT\SUB\FILE2.TXT
DIFF -s B:\XCOPY\EXAMPLES\01_VERFY\SRC\ROOT\SUB\SECRET.TXT C:\XCOPYCHK\ROOT\SUB\SECRET.TXT
